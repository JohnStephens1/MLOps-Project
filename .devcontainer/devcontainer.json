{
    "name": "TextOps",
    "dockerComposeFile": "../compose.yaml",
    "service": "dev",
    "runServices": ["dev"],
    "workspaceFolder": "/app",

    "overrideCommand": true,

    "shutdownAction": "stopCompose",

    "customizations": {
        "vscode": {
            "extensions": [
                // "caenrigen.jupytext-sync",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter",
                "tamasfe.even-better-toml"
            ]
        }
    }
}
