{
    "name": "MLOps-Project",
    "dockerComposeFile": "../compose.yaml",
    "service": "notebook",
    "runServices": ["notebook"],
    "workspaceFolder": "/app",

    "overrideCommand": true,

    "shutdownAction": "stopCompose",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                // "caenrigen.jupytext-sync",
                "ms-toolsai.jupyter"
            ]
        }
    }
}
